{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Panduan Pengguna Skoola Space",
  "description": "Step-by-step guides for every product—platform setup, analytics, and integrations in one place.",
  "colors": {
    "primary": "#37618A",
    "light": "#37618A",
    "dark": "#37618A"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "assistant",
      "mcp",
      "add-mcp"
    ]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "skoolacloud.id",
          "icon": "external-link",
          "href": "https://skoolacloud.id"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Pengenalan",
        "icon": "info",
        "expanded": true,
        "pages": [
          "index",
          "pengenalan/cara-mengakses-aplikasi",
          "pengenalan/cara-keluar-aplikasi",
          "pengenalan/cara-ubah-password"
        ]
      },
      {
        "group": "Fitur",
        "icon": "clipboard-check",
        "expanded": true,
        "pages": [
          "fitur/beranda",
          "fitur/dashboard",
          "fitur/kursusku",
          {
            "group": "Administrasi situs",
            "icon": "graduation-cap",
            "pages": [
              "fitur/admin-situs/umum",
              "fitur/admin-situs/pengguna",
              "fitur/admin-situs/kursus",
              "fitur/admin-situs/nilai",
              "fitur/admin-situs/pengaya",
              "fitur/admin-situs/tampilan",
              "fitur/admin-situs/server",
              "fitur/admin-situs/laporan",
              "fitur/admin-situs/pengembangan"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/light.png",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://space.skoolacloud.id"
    }
  },
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/skoolacloud/"
    }
  }
}
